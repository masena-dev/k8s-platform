# ---------------------------------------------------------------------------
# Hetzner Cloud
# ---------------------------------------------------------------------------

# Hetzner credentials
export TF_VAR_hcloud_token=""
export TF_VAR_ssh_public_key=""                    # key contents, use $(cat ~/.ssh/id_ed25519.pub)
export TF_VAR_ssh_private_key=""                   # key contents, use $(cat ~/.ssh/id_ed25519)

# Cluster
export TF_VAR_cluster_name="hetzner-starter"
export TF_VAR_cloud_provider="hetzner"
export CLUSTER=hetzner-starter

# Uncomment if you enable Hetzner Object Storage in Stage 1
# export TF_VAR_object_storage_access_key=""
# export TF_VAR_object_storage_secret_key=""
# Uncomment to reuse an existing Hetzner SSH key instead of creating one
# export TF_VAR_hcloud_ssh_key_id=""
