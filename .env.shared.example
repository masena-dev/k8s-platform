# K8s Starter Kit — Shared Environment Variables
#
# Copy this file to .env, then append your cloud-specific file:
#   cp .env.shared.example .env
#   cat .env.ovh.example >> .env        # or .env.hetzner.example
#   cat .env.oidc.example >> .env       # optional: SSO for kubectl, Grafana, ArgoCD
#   cat .env.extras.example >> .env    # optional: GHCR, GitHub token for private repos
#
# Fill in the values, then: source .env
# NEVER commit .env to git.
#
# WARNING: Only run the cp/cat steps once. If you need to start over,
# delete .env first to avoid duplicate exports.

# ---------------------------------------------------------------------------
# Terraform remote state (S3-compatible backend)
# ---------------------------------------------------------------------------
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ---------------------------------------------------------------------------
# 1Password
# ---------------------------------------------------------------------------
export TF_VAR_onepassword_service_account_token=""
export OP_SERVICE_ACCOUNT_TOKEN="${OP_SERVICE_ACCOUNT_TOKEN:-$TF_VAR_onepassword_service_account_token}"
export TF_VAR_onepassword_infra_vault=""          # vault name, e.g. "Starter Kit Infra"
export TF_VAR_onepassword_infra_vault_id=""       # vault UUID (Settings > Vaults > UUID in URL)
export TF_VAR_onepassword_team_logins_vault_id="" # vault UUID for browser-login items (ArgoCD, Grafana, etc.)
# Can be the same vault as infra, or a separate vault shared with your team.

# ---------------------------------------------------------------------------
# Bootstrap
# ---------------------------------------------------------------------------
export TF_VAR_cloudflare_api_token=""
export TF_VAR_domain=""                           # e.g. example.com
export TF_VAR_letsencrypt_email=""

# ---------------------------------------------------------------------------
# ArgoCD
# ---------------------------------------------------------------------------
export TF_VAR_argocd_repo_url=""                  # your fork URL

# ---------------------------------------------------------------------------
# Addons stage — reads cluster state from this bucket
# ---------------------------------------------------------------------------
export TF_VAR_state_bucket=""
export TF_VAR_state_region=""                     # S3 bucket location code: "gra" for OVH, "fsn1" for Hetzner.
# Must match where you created the bucket. NOT the cluster region (e.g. GRA9).
export TF_VAR_state_endpoint=""                   # e.g. https://s3.gra.io.cloud.ovh.net

# ---------------------------------------------------------------------------
# Optional overrides (defaults work for most setups)
# ---------------------------------------------------------------------------
# export TF_VAR_grafana_admin_password=""         # leave empty to auto-generate
# export TF_VAR_argocd_target_revision="main"     # branch ArgoCD tracks
