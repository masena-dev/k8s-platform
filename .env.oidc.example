# ---------------------------------------------------------------------------
# OIDC / SSO (optional — skip this file for a basic setup)
#
# Enables single sign-on for kubectl, Grafana, and ArgoCD.
# Create OAuth clients in your identity provider first. See docs/oidc.md.
# Defaults are for Google; override URLs for other providers (Okta, Azure AD, Dex).
#
# WARNING (Hetzner): enable_oidc must be true BEFORE the first cluster apply.
# kube-hetzner bakes OIDC flags into k3s at install time — they cannot be
# added to an existing cluster. See docs/oidc.md for details.
# ---------------------------------------------------------------------------

# Cluster-stage OIDC (configures the Kubernetes API server)
export TF_VAR_enable_oidc=true
export TF_VAR_oidc_issuer_url="https://accounts.google.com"
export TF_VAR_oidc_client_id=""
# export TF_VAR_oidc_username_claim="email"
# export TF_VAR_oidc_groups_claim="groups"
# export TF_VAR_oidc_username_prefix="oidc:"

# RBAC (addons stage — grant cluster access to OIDC users)
export TF_VAR_oidc_admins='[]'                     # e.g. '["ops@example.com"]'
export TF_VAR_oidc_viewers='[]'                    # e.g. '["dev@example.com"]'

# kubectl OIDC (writes an OIDC kubeconfig to 1Password)
export TF_VAR_kubectl_oidc_client_id=""
export TF_VAR_kubectl_oidc_client_secret=""

# Allowed email domains (shared by ArgoCD + Grafana OIDC)
export TF_VAR_oidc_allowed_domains=""               # e.g. "example.com" or "example.com,example.dev"

# Grafana OAuth
export TF_VAR_grafana_oauth_client_id=""
export TF_VAR_grafana_oauth_client_secret=""
# Provider URLs default to Google — override for Okta, Azure AD, etc.
# export TF_VAR_grafana_oauth_auth_url="https://accounts.google.com/o/oauth2/v2/auth"
# export TF_VAR_grafana_oauth_token_url="https://oauth2.googleapis.com/token"
# export TF_VAR_grafana_oauth_api_url="https://openidconnect.googleapis.com/v1/userinfo"
# export TF_VAR_grafana_oauth_scopes="openid email profile"

# ArgoCD OIDC
export TF_VAR_argocd_oidc_client_id=""
export TF_VAR_argocd_oidc_client_secret=""

