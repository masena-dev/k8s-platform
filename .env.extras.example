# ---------------------------------------------------------------------------
# Extras (optional — skip this file for a basic setup)
#
# Private container registry, private repo access, and team login items.
# Append to .env:  cat .env.extras.example >> .env
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Private container registry (GHCR)
# Set ghcr_username to enable pulling private images from GHCR.
# ghcr_token needs read:packages scope. If empty, falls back to github_token.
# ---------------------------------------------------------------------------
export TF_VAR_ghcr_username=""
export TF_VAR_ghcr_token=""

# ---------------------------------------------------------------------------
# GitHub token (private repo access for ArgoCD)
# Only needed if your fork is a private repository.
# ---------------------------------------------------------------------------
export TF_VAR_github_token=""

# Team logins vault moved to .env.shared.example (it's not really optional).
